# AEGIS web — PRODUCTION env (set these in the Vercel dashboard, or via `vercel env`).
# NEXT_PUBLIC_* values are inlined at BUILD time, so a change requires a redeploy.

# Base URL of the deployed FastAPI backend on Render (no trailing slash).
NEXT_PUBLIC_API_URL=https://sentinelgraph-backend.onrender.com

# Must be "false" in production so the app uses the live backend, not seeded mock data.
NEXT_PUBLIC_MOCK_ONLY=false
