# SentinelGraph web configuration.
# The frontend only ever talks to the FastAPI backend over HTTP.

# Base URL of the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Live by default: the app calls the real backend and only falls back to seeded
# demo data if a request fails. Set to "true" to force offline/demo mode.
NEXT_PUBLIC_MOCK_ONLY=false
