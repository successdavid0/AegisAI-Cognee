# SentinelGraph web configuration.
# The frontend only ever talks to the FastAPI backend over HTTP.

# Base URL of the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# When "true" (default), the app never calls the network and serves seeded
# demo data. Set to "false" once the backend is running to use live data.
NEXT_PUBLIC_MOCK_ONLY=true
