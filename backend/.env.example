# SentinelGraph backend configuration (Backend Spec §12).

APP_ENV=development
DATABASE_URL=sqlite:///./sentinelgraph.db

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Cognee memory ---
COGNEE_DATASET=global-threat-intel
# Provide these to activate real Cognee calls. When empty, the backend runs in
# graceful local-simulation mode (memory lifecycle still works, persisted in DB).
COGNEE_BASE_URL=
COGNEE_API_KEY=
# Only needed for Cognee local SDK mode.
OPENAI_API_KEY=
