# Keep the image lean and secrets out.
.venv/
venv/
__pycache__/
*.py[cod]

# Secrets — provided as env vars on the host, never baked into the image.
.env
.env.*
!.env.example

# Local state — a fresh DB is created + seeded on startup (persisted on the disk).
*.db
*.sqlite3
*.log

# Cloned external datasets — re-fetched on demand by the import script.
data/external/

# Docs / tooling not needed at runtime.
README.md
